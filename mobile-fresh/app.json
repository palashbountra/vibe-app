{
  "expo": {
    "name": "Vibe",
    "slug": "vibe-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibeapp",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibeapp.vibe"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.vibeapp.vibe",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vibe needs access to your photos to let you add profile pictures.",
          "cameraPermission": "Vibe needs access to your camera to take profile pictures."
        }
      ],
      "expo-web-browser"
    ],
    "platforms": ["ios", "android"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6706010-19c7-489f-92e7-688849ba1d68"
      }
    },
    "owner": "palashbountra",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a6706010-19c7-489f-92e7-688849ba1d68"
    }
  }
}
