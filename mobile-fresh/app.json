{
  "expo": {
    "name": "Vibe",
    "slug": "vibe-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibeapp",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibeapp.vibe"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.vibeapp.vibe"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vibe needs access to your photos to let you add profile pictures.",
          "cameraPermission": "Vibe needs access to your camera to take profile pictures."
        }
      ],
      "expo-web-browser"
    ]
  }
}
